# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# --- Your private config (copied from config.example.yaml on first run) ---
config.yaml

# --- Your private data: conversations and memories ---
data/
*.db
*.sqlite3

# --- Environment / secrets ---
.env

# --- Generated voice sample (from verify_tts.py) ---
verify/nero_voice_sample.wav

# --- Downloaded neural-voice model files (large; fetched on first use) ---
models/

# --- Claude Code (shared .claude/settings.json is committed; personal overrides are not) ---
.claude/settings.local.json

# --- Editor / OS junk ---
.vscode/
.idea/
.DS_Store
Thumbs.db

_nero_preview/

# Nero School runtime attempts and notification signals
School/*/Task_*/runs/
School/DEBATE CC/.signals/*.pending.json
School/DEBATE CC/.signals/archive/

# Nero cross-host continuity: live ledger, backups, journals, exports (never committed).
# (data/ is already ignored above; these patterns are defensive belt-and-suspenders.)
data/continuity/
*.db-journal
*.db-wal
*.db-shm
*.continuity-export.json
